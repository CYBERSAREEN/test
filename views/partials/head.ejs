<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=5"
    />
    <meta name="description" content="<%= description %>" />
    <meta name="keywords" content="<%= keywords %>" />
    <meta name="author" content="The Raw Studios" />
    <meta name="robots" content="index, follow" />
    <meta name="language" content="English" />
    <meta name="revisit-after" content="7 days" />

    <!-- Open Graph -->
    <meta property="og:title" content="<%= ogTitle %>" />
    <meta property="og:description" content="<%= ogDescription %>" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://rawstudios.co" />
    <meta
      property="og:image"
      content="https://rawstudios.co/images/og-image.jpg"
    />
    <meta property="og:site_name" content="The Raw Studios" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="<%= ogTitle %>" />
    <meta name="twitter:description" content="<%= ogDescription %>" />
    <meta
      name="twitter:image"
      content="https://rawstudios.co/images/og-image.jpg"
    />

    <!-- Canonical -->
    <link rel="canonical" href="<%= canonical %>" />

    <title><%= title %></title>

    <!-- Bootstrap 5 -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
    />
    <!-- Font Awesome 6 -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
    />
    <!-- Google Fonts: Bebas Neue (funky display) + Great Vibes + Playfair + Poppins + Space Grotesk -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bangers&family=Bebas+Neue&family=Great+Vibes&family=Playfair+Display:ital,wght@0,600;0,700;1,600&family=Poppins:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <!-- Swiper -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"
    />
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css" />
    <!-- Favicon -->
    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎵</text></svg>"
    />

    <!-- Meta Pixel Code -->
    <script>
      !(function (f, b, e, v, n, t, s) {
        if (f.fbq) return;
        n = f.fbq = function () {
          n.callMethod
            ? n.callMethod.apply(n, arguments)
            : n.queue.push(arguments);
        };
        m;
        if (!f._fbq) f._fbq = n;
        n.push = n;
        n.loaded = !0;
        n.version = "2.0";
        n.queue = [];
        t = b.createElement(e);
        t.async = !0;
        t.src = v;
        s = b.getElementsByTagName(e)[0];
        s.parentNode.insertBefore(t, s);
      })(
        window,
        document,
        "script",
        "https://connect.facebook.net/en_US/fbevents.js",
      );
      fbq("init", "1355074056674540");
      fbq("track", "PageView");
    </script>
    <noscript
      ><img
        height="1"
        width="1"
        style="display: none"
        src="https://www.facebook.com/tr?id=1355074056674540&ev=PageView&noscript=1"
    /></noscript>
    <!-- End Meta Pixel Code -->

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "The Raw Studios",
        "description": "Premier music and dance academy offering professional classes in singing, guitar, piano, flute, drums, violin, sitar, clapbox, classical dance, bhangra, western dance, and yoga in Zirakpur, Ludhiana, and Chandigarh (Tri-City)",
        "image": "https://rawstudios.co/images/logo.jpg",
        "telephone": "+91-XXXXXXXXXX",
        "email": "contact@rawstudios.co",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Zirakpur",
          "addressLocality": "Zirakpur",
          "addressRegion": "Punjab",
          "postalCode": "140603",
          "addressCountry": "IN"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": "30.6386",
          "longitude": "76.8122"
        },
        "url": "https://rawstudios.co",
        "sameAs": [
          "https://www.facebook.com/rawstudios",
          "https://www.instagram.com/rawstudios",
          "https://www.youtube.com/rawstudios"
        ],
        "priceRange": "₹2499-₹4000",
        "knowsAbout": [
          "Singing Classes",
          "Guitar Classes",
          "Piano Classes",
          "Flute Classes",
          "Drums Classes",
          "Violin Classes",
          "Sitar Classes",
          "Clapbox Classes",
          "Classical Dance",
          "Bhangra Dance",
          "Western Dance",
          "Yoga",
          "Music Education",
          "Dance Education"
        ],
        "areaServed": [
          {
            "@type": "City",
            "name": "Zirakpur"
          },
          {
            "@type": "City",
            "name": "Ludhiana"
          },
          {
            "@type": "City",
            "name": "Chandigarh"
          }
        ]
      }
    </script>
  </head>
  <body>
    <!-- ══════════════════════════════════════════════
     FULL-SCREEN PAGE LOADER (dismissed by JS on load)
═══════════════════════════════════════════════ -->
    <div id="trs-loader" aria-hidden="true">
      <div class="loader-orb lo-1"></div>
      <div class="loader-orb lo-2"></div>
      <div class="loader-orb lo-3"></div>
      <div class="loader-staff-lines" aria-hidden="true">
        <span></span><span></span><span></span><span></span><span></span>
      </div>
      <div class="loader-content">
        <i class="fa-solid fa-music loader-music-icon"></i>
        <div class="loader-brand-text">The Raw Studios</div>
        <p class="loader-tagline">
          Music &nbsp;&middot;&nbsp; Dance &nbsp;&middot;&nbsp; Art
        </p>
        <div class="loader-progress-wrap">
          <div class="loader-progress-track">
            <div class="loader-progress-fill"></div>
          </div>
        </div>
        <div class="loader-notes-row" aria-hidden="true">
          <span>&#9834;</span><span>&#9835;</span><span>&#9833;</span
          ><span>&#9836;</span><span>&#9837;</span>
        </div>
      </div>
    </div>
  </body>
</html>
